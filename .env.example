# Copy this file to .env and fill in real values. Never commit .env.

# --- YouTube (Google Cloud OAuth client, Desktop app type) ---
YOUTUBE_CLIENT_SECRETS_FILE=./secrets/youtube_client_secret.json
YOUTUBE_TOKEN_FILE=./secrets/youtube_token.json

# --- TikTok Content Posting API ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# --- Instagram / Meta Graph API ---
IG_BUSINESS_ACCOUNT_ID=
IG_ACCESS_TOKEN=

# --- ngrok (temporary public hosting for Instagram uploads, no credit card) ---
NGROK_AUTHTOKEN=

# --- Google Cloud Storage (alternative to ngrok above, not required) ---
GCS_BUCKET_NAME=
GCS_SERVICE_ACCOUNT_FILE=./secrets/gcs_service_account.json

# --- Whop / Content Rewards (for the notifier, once endpoints are confirmed) ---
WHOP_API_KEY=
